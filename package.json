{
  "name": "md2linkedin",
  "version": "0.6.0",
  "description": "Convert Markdown to LinkedIn-ready output — an article or a themeable carousel (PDF) — with the hard parts solved: aligned tables, syntax-highlighted code, and rendered mermaid diagrams.",
  "type": "module",
  "bin": {
    "md2li": "src/cli.js"
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/cli.js",
    "test": "node --test"
  },
  "keywords": [
    "markdown",
    "markdown-to-linkedin",
    "linkedin",
    "linkedin-article",
    "linkedin-formatter",
    "converter",
    "formatter",
    "tables",
    "code",
    "syntax-highlighting",
    "shiki",
    "carousel",
    "document-post",
    "pdf",
    "mermaid",
    "diagrams",
    "cli",
    "nodejs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankitpandey2708/md2linkedin.git"
  },
  "bugs": {
    "url": "https://github.com/ankitpandey2708/md2linkedin/issues"
  },
  "homepage": "https://github.com/ankitpandey2708/md2linkedin#readme",
  "author": "Ankit Pandey (https://github.com/ankitpandey2708)",
  "license": "MIT",
  "dependencies": {
    "@crosscopy/clipboard": "^0.3.6",
    "@resvg/resvg-js": "^2.6.2",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "pdfkit": "^0.19.1",
    "shiki": "^1.24.0"
  }
}